# ─── Database ────────────────────────────────────────
MYSQL_ROOT_PASSWORD=rootpass
MYSQL_USER=health_user
MYSQL_PASSWORD=health_pass
MYSQL_URL=mysql+aiomysql://health_user:health_pass@localhost:3306/health_platform

# ─── Redis ───────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── JWT Auth ────────────────────────────────────────
JWT_SECRET=change-me-to-a-long-random-string-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# ─── LLM / RAG ───────────────────────────────────────
# Option A: OpenAI (recommended for production)
OPENAI_API_KEY=sk-your-key-here
LLM_MODEL=gpt-3.5-turbo

# Option B: Local Ollama (free, set USE_LOCAL_LLM=true)
USE_LOCAL_LLM=false
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# ─── ChromaDB ────────────────────────────────────────
CHROMA_HOST=localhost
CHROMA_PORT=8001

# ─── App ─────────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
